---
// Import global styles so they apply to every page using this layout
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Required meta tags for proper rendering and mobile responsiveness -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Favicon for browser tabs (SVG and fallback ICO) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Astro auto-generates a <meta name="generator"> tag -->
    <meta name="generator" content={Astro.generator} />
    <title>Jacob's Garden</title>
  </head>
  <body>
    <div class="content-box">
      <!-- <slot /> renders whatever content is wrapped by this layout (the page content) -->
      <slot />
    </div>
  </body>
</html>

<style>
  html {
    height: 100%;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  body {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .content-box {
    width: 100%;
    max-width: 800px;
    background: #fff;
    border-radius: 24px;
    margin-top: var(--margin-top, 24px);
    margin-right: var(--margin-right, 48px);
    margin-bottom: var(--margin-bottom, 24px);
    margin-left: var(--margin-left, 48px);
  }
</style>
